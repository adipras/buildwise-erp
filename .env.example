# ============================================================
# BuildWise ERP — Environment Variables
# Salin file ini ke .env dan isi nilainya
# ============================================================

# App
APP_ENV=development   # development | production
PORT=8080

# Database MySQL
DB_DSN="buildwise:buildwise@tcp(localhost:3306)/buildwise_dev?parseTime=true&charset=utf8mb4&loc=UTC"

# Redis (untuk asynq queue)
REDIS_ADDR="localhost:6379"

# JWT
JWT_SECRET="ganti-dengan-random-string-min-32-karakter"
JWT_EXPIRES_HOURS=24

# WhatsApp via Fonnte API
FONNTE_TOKEN=""

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="buildwise"
R2_PUBLIC_URL=""      # URL publik bucket (opsional, untuk pre-signed URL)

# Sentry (error tracking, opsional)
SENTRY_DSN=""
